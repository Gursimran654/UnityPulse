// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  name           String
  role           String    // "NGO" or "VOLUNTEER"
  organization   String?
  skills         String?
  efficiency     Float     @default(100.0)
  impactHours    Float     @default(0.0)
  tasksCompleted Int       @default(0)
  lat            Float?
  lng            Float?
  createdAt      DateTime  @default(now())
  tasks          Task[]    @relation("VolunteerTasks")
  authoredTasks  Task[]    @relation("NGOTasks")
  reports        Report[]
}

model Hazard {
  id           String   @id @default(uuid())
  title        String
  description  String?
  location     String
  lat          Float?
  lng          Float?
  severity    String   @default("Unverified") // Unverified, Moderate, Severe, Critical
  status      String   @default("Active")     // Active, Resolved
  reportsCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  reports     Report[]
  tasks       Task[]
}

model Report {
  id        String   @id @default(uuid())
  hazard    Hazard   @relation(fields: [hazardId], references: [id])
  hazardId  String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}

model Task {
  id           String   @id @default(uuid())
  title        String
  description  String?
  location     String
  type         String
  priority     String   @default("Medium")
  status       String   @default("Open")   // Open, InProgress, Completed
  partnerOrg   String?                      // Name of partner NGO
  volunteersNeeded Int  @default(1)
  volunteer    User?    @relation("VolunteerTasks", fields: [volunteerId], references: [id])
  volunteerId  String?
  ngo          User     @relation("NGOTasks", fields: [ngoId], references: [id])
  ngoId        String
  hazard       Hazard?  @relation(fields: [hazardId], references: [id])
  hazardId     String?
  createdAt    DateTime @default(now())
}

model Survey {
  id        String   @id @default(uuid())
  title     String
  data      String   // JSON string of questions/responses
  createdAt DateTime @default(now())
}
